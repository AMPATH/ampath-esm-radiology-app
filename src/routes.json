{
  "$schema": "https://json.openmrs.org/routes.schema.json",
  "backendDependencies": {
    "fhir2": ">=1.2",
    "webservices.rest": ">=2.2.0"
  },
  "pages": [
    {
      "component": "root",
      "route": "radiology"
    }
  ],
  "extensions": [
    {
      "name": "radiology-dashboard-link",
      "component": "radiologyDashboardLink",
      "slot": "homepage-dashboard-slot",
      "meta": {
        "name": "radiology",
        "slot": "radiology-dashboard-slot",
        "title": "Radiology & Imaging"
      },
      "online": true,
      "offline": true
    },
    {
      "component": "root",
      "name": "radiology",
      "slot": "radiology-dashboard-slot"
    },
    {
      "name": "pickup-radiology-request-modal",
      "component": "pickupRadiologyRequestModal"
    },
    {
      "name": "reject-radiology-request-modal",
      "component": "rejectRadiologyRequestModal"
    },
    {
      "name": "pick-radiology-request-action",
      "component": "pickupRadiologyRequestAction",
      "slot": "radiology-ordered-actions-slot"
    },
    {
      "name": "generate-radiology-bill-request-action",
      "component": "generateBillRequestAction",
      "slot": "radiology-ordered-actions-slot"
    },
    {
      "name": "reject-radiology-request-action",
      "component": "rejectRadiologyRequestAction",
      "slot": "rejected-ordered-radiology-actions-slot"
    },
    {
      "name": "add-radiology-request-results-action",
      "component": "addRadiologyRequestResultsAction",
      "slot": "inprogress-radiology-tests-actions-slot"
    },
    {
      "name": "ordered-radiology-requests-table",
      "slot": "radiology-panels-slot",
      "order": 0,
      "component": "orderedRequestsTable",
      "meta": {
        "name": "orderedRadiologyPanel",
        "title": "Radiology ordered"
      }
    },
    {
      "name": "inprogress-radiology-requests-table",
      "slot": "radiology-panels-slot",
      "component": "inprogressRequestsTable",
      "order": 1,
      "meta": {
        "name": "inprogressRadiologyPanel",
        "title": "In progress"
      }
    },
    {
      "name": "completed-radiology-requests-table",
      "slot": "radiology-panels-slot",
      "component": "completedRequestsTable",
      "order": 2,
      "meta": {
        "name": "completedRadiologyPanel",
        "title": "Completed"
      }
    },
    {
      "name": "declined-radiology-requests-table",
      "slot": "radiology-panels-slot",
      "component": "declinedRequestsTable",
      "order": 3,
      "meta": {
        "name": "declinedRadiologyPanel",
        "title": "Declined"
      }
    },
    {
      "name": "ordered-radiology-requests-tile",
      "slot": "radiology-tiles-slot",
      "component": "orderedRequestsTile",
      "order": 0,
      "meta": {
        "name": "orderedRequestsTile",
        "title": "Radiology ordered"
      }
    },
    {
      "name": "inprogress-radiology-requests-tile",
      "slot": "radiology-tiles-slot",
      "component": "inProgressRequestsTile",
      "order": 1,
      "meta": {
        "name": "inprogressRequestsTile",
        "title": "In progress"
      }
    },
    {
      "name": "completed-radiology-requests-tile",
      "slot": "radiology-tiles-slot",
      "component": "completedRequestsTile",
      "order": 2,
      "meta": {
        "name": "completedRequestsTile",
        "title": "Completed"
      }
    },
    {
      "name": "declined-radiology-requests-tile",
      "slot": "radiology-tiles-slot",
      "component": "declinedRequestsTile",
      "order": 3,
      "meta": {
        "name": "declinedRequestsTile",
        "title": "Declined radiology"
      }
    }
  ],
  "workspaces": [
    {
      "name": "post-radiology-form-workspace",
      "component": "postRadiologyForm",
      "title": "radiology results",
      "type": "other-form"
    }
  ]
}